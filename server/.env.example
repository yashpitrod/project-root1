# ── Server (.env) ──
# MongoDB connection string
MONGO_URI=

# Firebase Admin SDK credentials (from Firebase Console > Service Accounts)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_CLIENT_CERT_URL=

# Gemini API key (from Google AI Studio)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-1.0

# Embedding provider: GEMINI or GROQ
EMBEDDING_PROVIDER=GEMINI

# Groq embedding configuration
GROQ_API_KEY=
GROQ_EMBEDDING_MODEL=groq-embedding-1.0
GROQ_API_URL=https://api.groq.ai/v1/embeddings

# Use GROQ if you want to avoid Gemini embeddings entirely.
# Set EMBEDDING_PROVIDER=GROQ and provide GROQ_API_KEY.

# Frontend URL for CORS (production)
FRONTEND_URL=

# Server port (defaults to 5000)
PORT=5000

# Doctor whitelist — comma-separated list of pre-approved doctor emails
# These users are auto-assigned the "doctor" role on registration
ALLOWED_DOCTOR_EMAILS=

# Environment (e.g., development, production)
NODE_ENV=production
