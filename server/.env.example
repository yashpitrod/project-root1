# ── Server (.env) ──
# MongoDB connection string
MONGO_URI=

# Firebase Admin SDK credentials (from Firebase Console > Service Accounts)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_CLIENT_CERT_URL=

# Groq API key (from console.groq.com)
GROQ_API_KEY=

# Frontend URL for CORS (production)
FRONTEND_URL=

# Server port (defaults to 5000)
PORT=5000

# Doctor whitelist — comma-separated list of pre-approved doctor emails
# These users are auto-assigned the "doctor" role on registration
ALLOWED_DOCTOR_EMAILS=

# Environment (e.g., development, production)
NODE_ENV=production
